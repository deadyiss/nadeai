# ─── Flask ───────────────────────────────────────────────
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
SECRET_KEY=ganti-dengan-string-acak-panjang-minimal-32-karakter

# ─── Database ────────────────────────────────────────────
DATABASE_URL=sqlite:///data/app.db
MAX_FILE_SIZE_MB=100

# ─── LLM Provider ────────────────────────────────────────
# Pilih salah satu: groq atau ollama
LLM_PROVIDER=groq

# Jika LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Jika LLM_PROVIDER=ollama (uncomment dan ganti LLM_MODEL di atas)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1:8b
# OLLAMA_HOST=http://127.0.0.1:11434

# ─── Embedding ───────────────────────────────────────────
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ─── Algorithm ───────────────────────────────────────────
HALLUCINATION_THRESHOLD=0.6
TOP_K_DOCUMENTS=5
SIMILARITY_MIN_THRESHOLD=0.15
NLI_ENTAILMENT_THRESHOLD=0.5
NLI_CONTRADICTION_THRESHOLD=0.5

# ─── Session ─────────────────────────────────────────────
SESSION_EXPIRE_HOURS=24

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Admin Bootstrap ─────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@local